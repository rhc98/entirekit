{
  "name": "entirekit",
  "version": "0.2.2",
  "description": "CLI toolkit for analyzing EntireKit data and installing git entirekit aliases",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "entirekit": "bin/entirekit"
  },
  "files": [
    "bin/",
    "dist/",
    ".entire/docs/",
    ".entire/ENTIREKIT.md",
    ".entire/ENTIREKIT.ko.md",
    ".entire/settings.json",
    ".claude/skills/entire-analytics/",
    ".claude/skills/entire-checkpoint/",
    "README.md",
    "README.ko.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm run build && npm run typecheck && npm test && npm run pack:check"
  },
  "keywords": [
    "entire",
    "checkpoint",
    "git",
    "cli",
    "analytics"
  ],
  "author": "bisu1200@gmail.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rhc98/entirekit.git"
  },
  "homepage": "https://github.com/rhc98/entirekit#readme",
  "bugs": {
    "url": "https://github.com/rhc98/entirekit/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "overrides": {
    "rollup": "^4.58.1"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.2.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "open": "^11.0.0",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
